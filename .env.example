# AI Provider Key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Keamanan Internal (WAJIB SAMA dengan Gateway)
INTERNAL_GATEWAY_SECRET=your_internal_gateway_secret_here

# Lokal Model (Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Safety Controls (DEV_MODE=true will refuse to boot in production/lifespan check)
DEV_MODE=false

# Postgres Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lerka

# Redis Configuration (split DBs)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB_CONTROL=0
REDIS_DB_CACHE=1

# App Settings
PROJECT_NAME="Lerka AI Worker"
API_V1_STR=/api/v1
ENVIRONMENT=development